# ─────────────────────────────────────────────────────────────
# SyncMeet – Variables de entorno
# Copia este archivo a .env y completa cada valor.
# NUNCA subas el .env real al repositorio ni al ZIP.
# ─────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────
# URI de conexión a MongoDB Atlas (o local).
# Ejemplo local:  mongodb://localhost:27017/syncmeet
# Ejemplo Atlas:  mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/syncmeet?retryWrites=true&w=majority
MONGO_URI=

# ── Seguridad JWT ─────────────────────────────────────────────
# Cadena aleatoria larga (mínimo 32 caracteres).
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Tiempo de expiración del token (ej: 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# ── Correo electrónico (nodemailer) ───────────────────────────
# Se recomienda usar una "Contraseña de aplicación" de Gmail
# (requiere verificación en 2 pasos activada en la cuenta).
EMAIL_USER=
EMAIL_PASS=

# ── Servidor ──────────────────────────────────────────────────
# Puerto en el que escucha el servidor Express.
# En Render se asigna automáticamente; puedes dejar 3000 para local.
PORT=3000

# ── CORS ──────────────────────────────────────────────────────
# Origen del frontend que tiene permitido consumir la API.
# Ejemplo local con Live Server de VS Code: http://localhost:5501
# Ejemplo en producción: https://tu-frontend.onrender.com
FRONTEND_URL=http://localhost:5501
